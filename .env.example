# Stripe (Pro plan checkout + webhook)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PRICE_ID=price_...        # the Pro recurring price
# STRIPE_WEBHOOK_SECRET=whsec_...  # from `stripe listen` or the dashboard webhook
# APP_URL=https://pencil.app        # used for success/cancel redirects
